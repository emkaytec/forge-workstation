export ZSH="$HOME/.oh-my-zsh"
export EDITOR={{ shell_default_editor }}
export VISUAL={{ shell_default_editor }}
export PAGER={{ shell_default_pager }}
export LESS=-FRX
export HISTSIZE={{ shell_history_size }}
export SAVEHIST={{ shell_history_file_size }}
export HISTFILE="$HOME/.zsh_history"

ZSH_THEME="{{ shell_zsh_theme }}"

plugins=({{ shell_zsh_plugins | join(' ') }})

source "$ZSH/oh-my-zsh.sh"

{% for alias_name, alias_value in shell_aliases.items() %}
alias {{ alias_name }}='{{ alias_value }}'
{% endfor %}

if [ -f "$HOME/.zshrc.local" ]; then
  source "$HOME/.zshrc.local"
fi
